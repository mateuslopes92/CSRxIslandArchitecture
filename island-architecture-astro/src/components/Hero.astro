---
---

<section class="hero">
  <div class="container">
    <div class="hero-content">
      <img src="https://avatars.githubusercontent.com/u/43526801?v=4" alt="Mateus Lopes" class="hero-avatar" />
      <h1>Mateus Lopes</h1>
      <p class="subtitle">Fullstack JavaScript Developer</p>
      <p class="description">
        ReactJS &bull; React Native &bull; NodeJS &bull; TypeScript
      </p>
      <div class="stats">
        <a href="https://github.com/mateuslopes92?tab=followers" target="_blank" class="stat">
          <strong>19</strong>
          <span>Followers</span>
        </a>
        <a href="https://github.com/mateuslopes92?tab=repositories" target="_blank" class="stat">
          <strong>74</strong>
          <span>Repos</span>
        </a>
        <a href="https://github.com/mateuslopes92?tab=following" target="_blank" class="stat">
          <strong>27</strong>
          <span>Following</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #16213e 0%, #1a1a2e 50%, #0f3460 100%);
    color: #fff;
    padding: 4rem 0;
    text-align: center;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .hero-avatar {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 4px solid #e94560;
    box-shadow: 0 0 30px rgba(233, 69, 96, 0.3);
  }

  h1 {
    font-size: 2.5rem;
    margin: 0;
    color: #fff;
  }

  .subtitle {
    font-size: 1.25rem;
    color: #e94560;
    font-weight: 600;
    margin: 0;
  }

  .description {
    color: #a0a0b8;
    font-size: 1rem;
    margin: 0;
  }

  .stats {
    display: flex;
    gap: 2rem;
    margin-top: 1rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: #fff;
    padding: 0.75rem 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    transition: background 0.2s;
  }

  .stat:hover {
    background: rgba(255, 255, 255, 0.1);
  }

  .stat strong {
    font-size: 1.5rem;
    color: #e94560;
  }

  .stat span {
    font-size: 0.875rem;
    color: #a0a0b8;
  }
</style>
